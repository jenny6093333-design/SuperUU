@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "重設密碼";
}

<section class="login-hero">
    <div class="login-shell">
        <div class="login-art">
            <h1>@ViewData["Title"]</h1>
            <p>請輸入新密碼完成重設。</p>
            <div class="signature">SuperUU 團隊</div>
        </div>
        <div class="login-panel">
            <h2>設定新密碼</h2>
            <div class="subtitle">此連結將在 30 分鐘後失效。</div>
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Input.Email" />
                <input type="hidden" asp-for="Input.Token" />
                <div class="mb-3">
                    <label class="form-label" asp-for="Input.Password"></label>
                    <input class="form-control" asp-for="Input.Password" type="password" autocomplete="new-password" />
                    <span class="text-danger" asp-validation-for="Input.Password"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label" asp-for="Input.ConfirmPassword"></label>
                    <input class="form-control" asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" />
                    <span class="text-danger" asp-validation-for="Input.ConfirmPassword"></span>
                </div>
                <button class="btn btn-primary w-100" type="submit">更新密碼</button>
            </form>
        </div>
    </div>
</section>
