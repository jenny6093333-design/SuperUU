@page
@model LoginModel
@{
    ViewData["Title"] = "登入";
}

<section class="login-hero">
    <div class="login-shell">
        <div class="login-art">
            <h1>@ViewData["Title"]</h1>
            <p>使用你的帳號登入 SuperUU。</p>
            <div class="signature">SuperUU 團隊</div>
        </div>
        <div class="login-panel">
            <h2>會員登入</h2>
            <div class="subtitle">請輸入帳號密碼。</div>
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="mb-3">
                    <label class="form-label" asp-for="Input.Username"></label>
                    <input class="form-control" asp-for="Input.Username" autocomplete="username" />
                    <span class="text-danger" asp-validation-for="Input.Username"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label" asp-for="Input.Password"></label>
                    <input class="form-control" asp-for="Input.Password" type="password" autocomplete="current-password" />
                    <span class="text-danger" asp-validation-for="Input.Password"></span>
                </div>
                <button class="btn btn-primary w-100" type="submit">登入</button>
            </form>
            <div class="helper">還沒有帳號？前往註冊或忘記密碼。</div>
        </div>
    </div>
</section>
