@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "忘記密碼";
}

<section class="login-hero">
    <div class="login-shell">
        <div class="login-art">
            <h1>@ViewData["Title"]</h1>
            <p>輸入你的電子郵件，我們會提供重設連結。</p>
            <div class="signature">SuperUU 團隊</div>
        </div>
        <div class="login-panel">
            <h2>重設密碼</h2>
            <div class="subtitle">請輸入註冊時的信箱。</div>
            @if (TempData["Info"] is string info)
            {
                <div class="alert alert-secondary">@info</div>
            }
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="mb-3">
                    <label class="form-label" asp-for="Input.Email"></label>
                    <input class="form-control" asp-for="Input.Email" type="email" autocomplete="email" />
                    <span class="text-danger" asp-validation-for="Input.Email"></span>
                </div>
                <button class="btn btn-primary w-100" type="submit">產生重設連結</button>
            </form>
            @if (TempData["ResetLink"] is string link)
            {
                <div class="mt-3">
                    <div class="text-muted">開發用重設連結：</div>
                    <a href="@link">@link</a>
                </div>
            }
            <div class="helper">想起密碼了？回到登入。</div>
        </div>
    </div>
</section>
